# J.A.R.V.I.S. local configuration
# Copy this file to .env. Never commit the populated .env file.

JARVIS_HOST=127.0.0.1
JARVIS_PORT=8787
HERMES_API_BASE=http://127.0.0.1:8642
HERMES_PROFILE=default

# Generated and populated by scripts/register_gateway.sh
HERMES_API_KEY=

JARVIS_WAKEWORD_THRESHOLD=0.55
JARVIS_VOICEPRINT_THRESHOLD=0.82
JARVIS_FACE_AUTH_ENABLED=false
JARVIS_FACE_THRESHOLD=65
JARVIS_AUTH_RP_ID=localhost
JARVIS_AUTH_ORIGIN=http://localhost:8787

# Optional ElevenLabs speech services
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STT_MODEL_ID=scribe_v1

# Local Whisper CLI fallback
JARVIS_WHISPER_MODEL=base
